{
  "name": "geneaindex",
  "version": "1.0.0",
  "private": true,
  "description": "Genealogical tree viewer — desktop application",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir --mac --universal",
    "dist:mac-avec-lanceur": "npm run pack && bash scripts/build-mac-avec-lanceur.sh",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.geneaindex.app",
    "productName": "Geneaindex",
    "icon": "assets/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "css/**/*",
      "js/**/*",
      "templates/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.education",
      "extendInfo": {
        "LSMinimumSystemVersion": "10.11.0"
      },
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "zip", "arch": ["universal"] }
      ]
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  },
  "devDependencies": {
    "electron": "^19.1.9",
    "electron-builder": "^23.6.0"
  }
}
